<section class="dashboard">

    <div class="container">

        <!-- HEADER -->

        <div class="dashboard-header">

            <div>

                <h1 class="dashboard-title">
                    Dashboard de Países
                </h1>

                <p class="dashboard-subtitle">

                    Gestión de países hispanohablantes
                    de América

                </p>

            </div>

            <a
                href="/countries/create"
                class="btn-primary"
            >

                + Nuevo País

            </a>

        </div>

        <!-- TABLE WRAPPER -->

        <div class="table-wrapper">

            <table class="countries-table">

                <thead>

                    <tr>

                        <th>Bandera</th>
                        <th>País</th>
                        <th>Capital</th>
                        <th>Fronteras</th>
                        <th>Área</th>
                        <th>Población</th>
                        <th>Gini</th>
                        <th>Timezones</th>
                        <th>Creador</th>
                        <th>Acciones</th>

                    </tr>

                </thead>

                <tbody>

                    <% countries.forEach(country => { %>

                        <tr>

                            <!-- FLAG -->

                            <td>

                                <img
                                    src="<%= country.flag %>"
                                    alt="<%= country.name %>"
                                    class="table-flag"
                                >

                            </td>

                            <!-- NAME -->

                            <td class="country-name">

                                <%= country.name %>

                            </td>

                            <!-- CAPITAL -->

                            <td>

                                <%= country.capital || 'N/A' %>

                            </td>

                            <!-- BORDERS -->

                            <td>

                                <div class="badge-group">

                                    <% if(country.borders?.length) { %>

                                        <% country.borders.forEach(border => { %>

                                            <span class="table-badge">

                                                <%= border %>

                                            </span>

                                        <% }) %>

                                    <% } else { %>

                                        <span class="text-muted">

                                            Sin datos

                                        </span>

                                    <% } %>

                                </div>

                            </td>

                            <!-- AREA -->

                            <td>

                                <%= country.area?.toLocaleString() || 'N/A' %> km²

                            </td>

                            <!-- POPULATION -->

                            <td>

                                <%= country.population?.toLocaleString() || 'N/A' %>

                            </td>

                            <!-- GINI -->

                            <td>

                                <%= country.gini || 'N/A' %>

                            </td>

                            <!-- TIMEZONES -->

                            <td>

                                <div class="badge-group">

                                    <% if(country.timezones?.length) { %>

                                        <% country.timezones.forEach(zone => { %>

                                            <span class="table-badge timezone">

                                                <%= zone %>

                                            </span>

                                        <% }) %>

                                    <% } %>

                                </div>

                            </td>

                            <!-- CREADOR -->

                            <td>

                                <%= country.creador || 'Sistema' %>

                            </td>

                            <!-- ACTIONS -->

                            <td>

                                <div class="table-actions">

                                    <a
                                        href="/countries/edit/<%= country._id %>"
                                        class="btn-edit"
                                    >

                                        Editar

                                    </a>

                                    <form
                                        action="/countries/<%= country._id %>?_method=DELETE"
                                        method="POST"
                                    >

                                        <button
                                            type="submit"
                                            class="btn-delete"
                                        >

                                            Eliminar

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</section>
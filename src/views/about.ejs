<!-- ===== ABOUT SECTION ===== -->
<section class="about">

    <div class="container">

        <!-- HERO -->

        <div class="about-hero">

            <span class="about-badge">
                Proyecto Full Stack
            </span>

            <h1 class="about-title">
                Sobre el Proyecto
            </h1>

            <p class="about-text">

                Aplicación web desarrollada como parte
                de la Diplomatura Universitaria en
                Desarrollo Web Full Stack dictada por
                el Nodo Tecnológico de Catamarca.

            </p>

        </div>

        <!-- GRID -->

        <div class="about-grid">

            <!-- CARD PROYECTO -->

            <article class="about-card">

                <h2>
                    Objetivo
                </h2>

                <p>

                    El proyecto permite visualizar,
                    gestionar y administrar información
                    de países hispanohablantes de América
                    mediante un CRUD completo conectado
                    a MongoDB.

                </p>

            </article>

            <!-- CARD STACK -->

            <article class="about-card">

                <h2>
                    Tecnologías
                </h2>

                <ul class="tech-list">

                    <li>Node.js</li>
                    <li>Express</li>
                    <li>MongoDB</li>
                    <li>Mongoose</li>
                    <li>EJS</li>
                    <li>CSS3</li>

                </ul>

            </article>

            <!-- CARD FEATURES -->

            <article class="about-card">

                <h2>
                    Características
                </h2>

                <ul class="feature-list">

                    <li>CRUD completo</li>

                    <li>Arquitectura MVC</li>

                    <li>Consumo de API REST</li>

                    <li>Responsive Design</li>

                    <li>Feedback visual personalizado</li>

                </ul>

            </article>

            <!-- CARD AUTOR -->

            <article class="about-card">

                <h2>
                    Desarrollador
                </h2>

                <p>

                    Proyecto desarrollado por
                    Marcos Batallán como práctica
                    académica orientada al desarrollo
                    de aplicaciones Full Stack modernas.

                </p>

            </article>

        </div>

    </div>

</section>

<!-- ===== CONTACT SECTION ===== -->
<section class="contact-section">

    <div class="contact-card">

        <span class="contact-badge">
            Contacto
        </span>

        <h2 class="contact-title">
            ¿Quieres dejar un mensaje?
        </h2>

        <p class="contact-text">

            Puedes enviar sugerencias,
            comentarios o consultas
            relacionadas con el proyecto.

        </p>

        <form class="contact-form">

            <input
                type="text"
                placeholder="Nombre"
                required
            >

            <input
                type="email"
                placeholder="Correo electrónico"
                required
            >

            <textarea
                placeholder="Escribe tu mensaje..."
                rows="6"
                required
            ></textarea>

            <button
                type="submit"
                class="btn-primary"
            >

                Enviar mensaje

            </button>

        </form>

    </div>

</section>